{
  "manifest_version": 3,
  "name": "Catraz Guardian",
  "version": "0.1.0",
  "description": "Web3 transaction firewall for MetaMask and Phantom.",
  "permissions": ["storage"],
  "host_permissions": [
    "<all_urls>",
    "https://risk-engine.catraz.local/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Catraz Guardian",
    "default_popup": "popup.html"
  }
}
